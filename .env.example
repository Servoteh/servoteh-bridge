# =============================================================================
# Servoteh Bridge - environment variables
# =============================================================================
# Kopiraj u `.env` (NEMA git) i popuni stvarnim vrednostima.
# Na Windows serveru: stavi `.env` pored `package.json` ili koristi
# system env vars (vidi README.md → "Deployment").
# =============================================================================

# ---- BigTehn SQL Server (read-only nalog je preporuka) ----
BIGTEHN_SQL_SERVER=Vasa-SQL
BIGTEHN_SQL_PORT=5765
BIGTEHN_SQL_DATABASE=QBigTehn
BIGTEHN_SQL_USER=bridge_reader
BIGTEHN_SQL_PASSWORD=replace-me
# `true` ako server zahteva enkriptovani konekciju (Azure SQL i sl.).
# Lokalni SQL Server obično: false.
BIGTEHN_SQL_ENCRYPT=false
# `true` za self-signed sertifikate u LAN-u.
BIGTEHN_SQL_TRUST_SERVER_CERTIFICATE=true
# Connection pool / query timeout (ms)
BIGTEHN_SQL_REQUEST_TIMEOUT_MS=60000
BIGTEHN_SQL_CONNECTION_TIMEOUT_MS=15000
BIGTEHN_SQL_POOL_MIN=0
BIGTEHN_SQL_POOL_MAX=4

# ---- Supabase (SERVICE ROLE key — NIKAD ne commit-uj, NIKAD ne expose-uj klijentu) ----
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me-service-role-key

# ---- Scheduler ----
# Cron izrazi (vremenska zona iz `TZ` env var; po defaultu je sistemska).
# Kompletni katalozi (sektori, mašine, komitenti, radnici) — jednom dnevno.
SCHEDULE_CATALOGS_CRON=0 6 * * *
# Da li scheduler radi (false = samo manualni `npm run sync:once`)
SCHEDULER_ENABLED=true
# Vremenska zona (Europe/Belgrade da je sigurno)
TZ=Europe/Belgrade

# ---- Logger ----
# `info` (default), `debug` za razvoj, `warn` u tihu produkciju.
LOG_LEVEL=info
# Folder za log fajlove (relativan u odnosu na repo root)
LOG_DIR=logs
# Da li dodatno štampa pretty u console (development), produkcija = false
LOG_PRETTY=true

# ---- Identifikacija instance (za bridge_sync_log) ----
BRIDGE_INSTANCE_NAME=servoteh-bridge-prod

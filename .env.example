# =============================================================================
# Servoteh Bridge - environment variables
# =============================================================================
# Kopiraj u `.env` (NEMA git) i popuni stvarnim vrednostima.
# Na Windows serveru: stavi `.env` pored `package.json` ili koristi
# system env vars (vidi README.md → "Deployment").
# =============================================================================

# ---- BigTehn SQL Server (read-only nalog je preporuka) ----
BIGTEHN_SQL_SERVER=Vasa-SQL
BIGTEHN_SQL_PORT=5765
BIGTEHN_SQL_DATABASE=QBigTehn
BIGTEHN_SQL_USER=bridge_reader
BIGTEHN_SQL_PASSWORD=replace-me
# `true` ako server zahteva enkriptovani konekciju (Azure SQL i sl.).
# Lokalni SQL Server obično: false.
BIGTEHN_SQL_ENCRYPT=false
# `true` za self-signed sertifikate u LAN-u.
BIGTEHN_SQL_TRUST_SERVER_CERTIFICATE=true
# Connection pool / query timeout (ms)
BIGTEHN_SQL_REQUEST_TIMEOUT_MS=60000
BIGTEHN_SQL_CONNECTION_TIMEOUT_MS=15000
BIGTEHN_SQL_POOL_MIN=0
BIGTEHN_SQL_POOL_MAX=4

# ---- Supabase (SERVICE ROLE key — NIKAD ne commit-uj, NIKAD ne expose-uj klijentu) ----
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me-service-role-key

# ---- Scheduler ----
# Cron izrazi (vremenska zona iz `TZ` env var; po defaultu je sistemska).
# Kompletni katalozi (sektori, mašine, komitenti, radnici, vrste, predmeti) — dnevno.
SCHEDULE_CATALOGS_CRON=0 6 * * *
# Production tracking (RN, operacije, lansiranje, saglasnost, kretanje delova) — svakih 15 min.
SCHEDULE_PRODUCTION_CRON=*/15 * * * *
# Da li scheduler radi (false = samo manualni `npm run sync:once`)
SCHEDULER_ENABLED=true
# Vremenska zona (Europe/Belgrade da je sigurno)
TZ=Europe/Belgrade

# ---- Alerting (svi opcioni — ostavi prazno da isključiš) ----
# Telegram bot — najlakše setupovati:
#   1) Otvori @BotFather u Telegramu, /newbot, kopiraj TOKEN
#   2) Dodaj bota u grupu/private chat sa tobom
#   3) Pošalji bilo koju poruku botu, pa otvori:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      i kopiraj `chat.id` (npr. 123456789 ili -1001234567890 za grupu)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
#
# Generic webhook (Slack/Discord/Teams/Mattermost ili custom Cloudflare Worker).
# Šalje POST application/json sa { text, content, level, job, error_message, … }.
ALERT_WEBHOOK_URL=

# ---- Logger ----
# `info` (default), `debug` za razvoj, `warn` u tihu produkciju.
LOG_LEVEL=info
# Folder za log fajlove (relativan u odnosu na repo root)
LOG_DIR=logs
# Da li dodatno štampa pretty u console (development), produkcija = false
LOG_PRETTY=true

# ---- Identifikacija instance (za bridge_sync_log) ----
BRIDGE_INSTANCE_NAME=servoteh-bridge-prod

# =============================================================================
# Enable/disable grupa jobova po instanci (ista codebase, više mašina)
# =============================================================================
# BigTehn server (default): oba true. SCADA VM u kotlarnici: oba false.
ENABLE_JOB_CATALOGS=true
ENABLE_JOB_PRODUCTION=true

# =============================================================================
# SCADA relay (Energetika) — bridge za Scada_PLC aplikaciju (ista mašina)
# Dizajn: docs/scada/energetika-scada-integration.md (repo plan-montaze)
# =============================================================================
# Uključi SCADA petlje (snapshot + istorija + alarmi + komande)
SCADA_ENABLED=false
# Lokalni HTTP API Scada_PLC aplikacije (server.js, HTTP_PORT)
SCADA_BASE_URL=http://127.0.0.1:3000
# Koliko često se upisuje snapshot u Supabase (ms, min 2000)
SCADA_SNAPSHOT_MS=5000
# Koliko često se upisuju uzorci istorije (ms, min 15000)
SCADA_HISTORY_MS=60000
# Koliko često se poluju komande iz scada_commands (ms, min 1000)
SCADA_CMD_POLL_MS=2000
# HTTP timeout ka lokalnom SCADA API-ju (ms)
SCADA_HTTP_TIMEOUT_MS=8000
# KILL-SWITCH: false trenutno zaustavlja izvršavanje komandi (nadzor radi dalje)
SCADA_CONTROL=true
# Rate-limit izvršenih komandi po sistemu (komandi u minutu)
SCADA_CMD_RATE_PER_MIN=10
# Retencija scada_history (dana; 0 = bez brisanja)
SCADA_HISTORY_RETENTION_DAYS=90

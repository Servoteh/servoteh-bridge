# Kotlarnica SCADA — kopiraj u `.env` (nije u git-u) i popuni.
# Na Win servisu env se "peče" pri service:install (vidi service/install.js).

# ---- PLC (Unitronics JZ20-J-T40, PCOM/TCP) ----
SIMULATE=false                 # true = lažni podaci (razvoj), false = pravi PLC
PLC_IP=192.168.75.25
PLC_PORT=502
PLC_UNIT=1

# ---- Web ----
HTTP_PORT=3000

# ---- Loxone Miniserver (Nova zgrada — kotlarnica/grejanje/hladjenje) ----
LOXONE_HOST=192.168.75.130
LOXONE_USER=admin
LOXONE_PASS=                    # upiši lozinku (ne komituj)

# ---- Sigenergy solarna elektrana (Cloud OpenAPI — developer.sigencloud.com) ----
# Aktivira se kad su SIGEN_SYSTEM_ID + kredencijali zadati. Region za Srbiju = eu.
# Preporuka: AppKey/AppSecret (registracija account-ownera na developer portalu).
SIGEN_REGION=eu
SIGEN_SYSTEM_ID=                # systemId (ili VIŠE, odvojeno zarezom: id1,id2). Nađi sa: npm run sigen:discover
                                # ili u mySigen app: Settings → System Settings → About → System ID
SIGEN_APP_KEY=                  # AppKey sa developer.sigencloud.com
SIGEN_APP_SECRET=               # AppSecret
# Alternativa (umesto key) — mySigen nalog:
SIGEN_USER=
SIGEN_PASS=
SIGEN_POLL_MS=300000            # 5 min (API limit: 1 zahtev po endpointu / 5 min)
SIGEN_CONTROL=false             # kontrola režima — njihov OpenAPI trenutno NEMA kontrolne
                                # endpointe (Control=prazno). Stavi true tek kad Sigenergy odobri.

# ---- blue'Log solarna elektrana (FNE, meteocontrol X-Control @ lokalni REST) ----
# Aktivira se kad su BLUELOG_HOST + USER + PASS zadati. Lokalna prijava na sam logger
# (NE VCOM portal). Nezvanican interfejs — pri firmware update-u proveri: npm run bluelog:discover.
BLUELOG_HOST=192.168.75.15
BLUELOG_USER=FNEServoteh        # lokalno korisničko ime za web (http://192.168.75.15)
BLUELOG_PASS=                   # lozinka MALIM slovima (ne komituj)
BLUELOG_POLL_MS=30000           # REST poll interval (>=15000; podaci su 1-min rezolucije)

# ---- Hala 5 (Siemens S7-1200, AWP web most — Faza 1, bez izmena na PLC-u) ----
# Aktivira se kad je S7_HOST zadat. Čita/piše DB "Web" preko PLC web servera (admin/admin).
S7_HOST=192.168.75.12
S7_USER=admin
S7_PASS=admin
S7_POLL_MS=5000                 # web poll (>=2000)

# ---- Telegram alarmi (opciono — ostavi prazno da isključiš) ----
# 1) @BotFather -> /newbot -> TOKEN
# 2) dodaj bota u grupu, pošalji poruku, otvori
#    https://api.telegram.org/bot<TOKEN>/getUpdates  i uzmi chat.id
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

{
  "name": "servoteh-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Bridge servis: BigTehn (SQL Server, QBigTehn) -> Supabase cache. Read-only sinhronizacija kataloga + RN/operacije/napredak. Deploy: Windows Service na firma serveru.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "sync:once": "node src/index.js --once",
    "sync:departments": "node src/index.js --job=departments --once",
    "sync:machines": "node src/index.js --job=machines --once",
    "sync:customers": "node src/index.js --job=customers --once",
    "sync:workers": "node src/index.js --job=workers --once",
    "sync:worker-types": "node src/index.js --job=worker_types --once",
    "sync:quality-types": "node src/index.js --job=quality_types --once",
    "sync:positions": "node src/index.js --job=positions --once",
    "sync:items": "node src/index.js --job=items --once",
    "sync:locations": "node src/index.js --job=locations --once",
    "sync:catalogs": "node src/index.js --job=catalogs --once",
    "sync:work-orders": "node src/index.js --job=work_orders --once",
    "sync:lines": "node src/index.js --job=lines --once",
    "sync:launches": "node src/index.js --job=launches --once",
    "sync:approvals": "node src/index.js --job=approvals --once",
    "sync:part-movements": "node src/index.js --job=part_movements --once",
    "sync:production": "node src/index.js --job=production --once",
    "service:install": "node src/service/install.js",
    "service:uninstall": "node src/service/uninstall.js",
    "test:connection": "node src/cli/testConnection.js",
    "discover:columns": "node src/cli/discoverColumns.js",
    "list:tables": "node src/cli/listTables.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "mssql": "^11.0.1",
    "node-cron": "^3.0.3",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {}
}
